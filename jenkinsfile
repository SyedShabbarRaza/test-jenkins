pipeline {
    agent any

    environment {
     CONTAINER_NAME = 'jenkins'
        IMAGE_NAME = 'jenkins:latest'
     EMAIL = "syedshabbarraza208@gmail.com"
     PORT = "3000"
    }

    stages {
        stage("Clone Repo"){
            steps {
                git branch: 'main', url: "https://github.com/SyedShabbarRaza/test-jenkins.git"
            }
        }

        stage("Build Docker Image") {
            steps {
                sh "docker build -t ${IMAGE_NAME} ."
            }
        }
        stage("Stop and remove previous container"){
            steps {
                sh "docker stop ${CONTAINER_NAME} || true"
                sh "docker rm ${CONTAINER_NAME} || true" //true means ky aggar wo container pehly sy ho hi nahi to error na aye
            }
        }

        stage("Run Docker Container") {
            steps {
                sh "docker run -d -p ${PORT}:${PORT} --name ${CONTAINER_NAME} ${IMAGE_NAME}"
            }
        }

         stage("Send Email Notification") {
            steps {
                mail to: "${EMAIL}",
                     subject: "Jenkins Pipeline Success",
                     body: "Your Application is running on http://15.206.158.146:${PORT}/"
            }
        }
} 

}